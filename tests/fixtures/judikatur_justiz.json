            "Entscheidungsdatum": "1999-11-03",
            "Anmerkung": "Auch; nur T1; Beisatz: Hier: Längere depressive Reaktion und psychosexuelle Entwicklungsstörung. (T5)<br/>Veröff: SZ 72/165",
            "DokumentUrl": "https://www.ris.bka.gv.at/Dokument.wxe?Abfrage=Justiz&Dokumentnummer=JJT_19991103_OGH0002_0090OB00078_99G0000_000"
