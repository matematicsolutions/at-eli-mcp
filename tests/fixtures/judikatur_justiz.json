            "Anmerkung": "Auch; nur T1; Veröff: SZ 2007/101",
            "DokumentUrl": "https://www.ris.bka.gv.at/Dokument.wxe?Abfrage=Justiz&Dokumentnummer=JJT_20070626_OGH0002_0010OB00088_07H0000_000"
           },
           {
            "Geschaeftszahl": "6 Ob 248/09b",
            "Dokumenttyp": "Text",
            "Gericht": "OGH",
            "Entscheidungsdatum": "2010-01-14",
            "Anmerkung": "Vgl; Bem: Hier: Todesangst. (T12)",
            "DokumentUrl": "https://www.ris.bka.gv.at/Dokument.wxe?Abfrage=Justiz&Dokumentnummer=JJT_20100114_OGH0002_0060OB00248_09B0000_000"
