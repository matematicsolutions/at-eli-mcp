           {
            "Geschaeftszahl": "1 Ob 200/03y",
            "Dokumenttyp": "Text",
            "Gericht": "OGH",
            "Entscheidungsdatum": "2003-10-14",
            "Anmerkung": "Vgl; Beis wie T10; Beisatz: Hier: Behandlungsbedürftige posttraumatische Belastungsstörung mit Krankheitswert des Klägers aufgrund des an ihm begangenen Raubüberfalls. (T12)",
            "DokumentUrl": "https://www.ris.bka.gv.at/Dokument.wxe?Abfrage=Justiz&Dokumentnummer=JJT_20031014_OGH0002_0010OB00200_03Y0000_000"
